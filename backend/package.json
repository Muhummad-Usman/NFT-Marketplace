{
  "name": "nft-marketplace-backend",
  "version": "1.0.0",
  "description": "NFT Marketplace with ERC-721, ERC-1155 and ERC-2981 support",
  "main": "index.js",
  "scripts": {
    "test": "hardhat test",
    "compile": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.js --network sepolia",
    "deploy-local": "hardhat run scripts/deploy.js --network localhost",
    "node": "hardhat node",
    "server": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run node\""
  },
  "devDependencies": {
    "hardhat": "2.28.0",
    "@nomicfoundation/hardhat-toolbox": "4.0.0",
    "@nomicfoundation/hardhat-verify": "2.0.0",
    "@typechain/hardhat": "9.0.0",
    "hardhat-gas-reporter": "1.0.10",
    "solidity-coverage": "0.8.12",
    "ethers": "6.14.0",
    "chai": "4.4.1",
    "@types/chai": "4.3.11",
    "@types/mocha": "10.0.6",
    "@types/node": "20.11.5",
    "typescript": "5.3.3",
    "ts-node": "10.9.2",
    "typechain": "8.3.2",
    "dotenv": "16.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.0.0",
    "@pinata/sdk": "2.1.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "concurrently": "^8.2.0"
  },
  "directories": {
    "test": "test"
  },
